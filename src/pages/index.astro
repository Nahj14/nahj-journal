---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="NAHJ Journal publishes peer-reviewed transdisciplinary research across cultural and historical studies, neuro-humanities, cognitive theory, and critical modernity."
>

  <!-- HERO -->
  <section class="journal-hero">
    <div class="hero-inner">
      <div class="hero-content">
        <span class="section-label">Current Issue</span>
        <div class="gold-rule"></div>
        <h1 class="hero-heading">Volume 1 · Spring 2026</h1>
        <p class="hero-desc">
          A peer-reviewed, open access journal publishing original scholarship at the intersection
          of cultural and historical studies, neuro-humanities and cognitive theory, and critical
          modernity and social dynamics.
        </p>
        <div class="hero-tags">
          <span class="tag">Double-Blind Peer Review</span>
          <span class="tag">Open Access</span>
          <span class="tag">CC BY 4.0</span>
          <span class="tag">Twice Yearly</span>
        </div>
      </div>
      <div class="hero-issue-card">
        <div class="issue-card-label">Vol. 1 Issue 1</div>
        <div class="issue-card-title">Spring 2026</div>
        <div class="issue-card-theme">
          <span class="theme-label">Focus Theme</span>
          <span class="theme-value">Authority, Legitimacy &amp; Islamic Governance</span>
        </div>
        <div class="issue-card-meta">
          <div class="meta-row"><span>Articles</span><span>In production</span></div>
          <div class="meta-row"><span>Published</span><span>Spring 2026</span></div>
          <div class="meta-row"><span>Access</span><span>Free</span></div>
        </div>
        <a href="/archive" class="btn-gold" style="display:block;text-align:center;margin-top:1.5rem;">Browse Archive</a>
      </div>
    </div>
  </section>

  <!-- ARTICLES FORTHCOMING -->
  <section class="section-articles">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-label">Publications</span>
          <div class="gold-rule"></div>
          <h2 class="section-h2">Articles</h2>
        </div>
        <a href="/archive" class="all-link">View archive →</a>
      </div>

      <div class="forthcoming-notice">
        <div class="forthcoming-inner">
          <div class="forthcoming-icon">◆</div>
          <div class="forthcoming-body">
            <div class="forthcoming-title">Volume 1, Issue 1 is in production</div>
            <p class="forthcoming-text">
              The inaugural issue of NAHJ Journal is currently in final preparation. Articles will appear
              here upon publication. We welcome submissions for Volume 2, Autumn 2026.
            </p>
            <div class="forthcoming-actions">
              <a href="/submit/manuscript" class="btn-gold">Submit a Manuscript</a>
              <a href="/submit" class="btn-outline">Author Guidelines</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AIMS & SCOPE -->
  <section class="section-scope">
    <div class="container">
      <div class="scope-grid">
        <div class="scope-left">
          <span class="section-label">About the Journal</span>
          <div class="gold-rule"></div>
          <h2 class="section-h2">Aims &amp; Scope</h2>
          <p>
            NAHJ Journal publishes original peer-reviewed research across the humanities and social
            sciences, with a particular concern for transdisciplinary inquiry and the recovery of
            non-Western intellectual frameworks. We welcome work that is rigorous in method,
            substantive in its engagement with primary scholarship, and alert to the questions that
            define intellectual life in the present. The journal does not privilege any single
            disciplinary method or civilisational tradition. It asks only that the scholarship be
            serious and the argument be clear.
          </p>
          <p>
            We publish research articles, review essays, and research notes. All submissions
            undergo double-blind peer review. The journal is fully open access with no article
            processing charges.
          </p>
          <a href="/submit" class="btn-primary">Submit Your Research</a>
        </div>
        <div class="scope-right">
          <div class="scope-areas">
            <div class="scope-area-title">Focus Areas</div>
            {[
              'Cultural and historical studies, including intellectual history, material culture, and literary and narrative theory',
              'Philosophy of mind, consciousness, and cognitive theory in dialogue with classical and contemporary scholarship',
              'Critical social theory, including decolonial epistemologies, political philosophy, and the ethics of governance',
              'Islamic intellectual history as a primary resource for transdisciplinary inquiry',
              'Comparative civilisational studies and cross-cultural intellectual exchange',
              'Science, technology, and the ethics of the human condition',
              'Religion, secularism, and the contested boundaries of public life',
              'Society, identity, and the politics of Muslim communities globally',
            ].map(area => (
              <div class="scope-item">
                <span class="scope-dot">◆</span>
                <span>{area}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- JOURNAL SPECS -->
  <section class="section-specs">
    <div class="container">
      <span class="section-label">Journal Information</span>
      <div class="gold-rule"></div>
      <div class="specs-grid">
        {[
          { label: 'Publisher', value: 'Nahj Institute' },
          { label: 'Frequency', value: 'Twice yearly' },
          { label: 'Review Process', value: 'Double-blind peer review' },
          { label: 'Access Type', value: 'Fully open access' },
          { label: 'Article Charges', value: 'None. Free to submit and publish.' },
          { label: 'Licence', value: 'CC BY 4.0' },
          { label: 'First Issue', value: 'Spring 2026' },
          { label: 'ISSN', value: 'Pending registration' },
        ].map(spec => (
          <div class="spec-item">
            <div class="spec-label">{spec.label}</div>
            <div class="spec-value">{spec.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CALL FOR SUBMISSIONS -->
  <section class="section-cfs">
    <div class="container-narrow">
      <span class="section-label" style="color:var(--gold-light)">Open for Submissions</span>
      <div class="gold-rule"></div>
      <h2 class="cfs-heading">Call for Papers — Vol. 2 · Autumn 2026</h2>
      <p class="cfs-text">
        NAHJ Journal invites submissions for Volume 2, Autumn 2026. We welcome original research
        articles of 6,000 to 10,000 words and review essays of 3,000 to 6,000 words. Submissions
        are accepted on a rolling basis. All published research is freely available without embargo
        or subscription.
      </p>
      <div class="cfs-buttons">
        <a href="/submit/manuscript" class="btn-gold">Submit a Manuscript</a>
        <a href="/submit" class="btn-outline-light">Author Guidelines</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
/* HERO */
.journal-hero {
  background: var(--cream);
  border-bottom: 1px solid var(--border);
  padding: 4rem 0 3.5rem;
}

.hero-inner {
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 4rem;
  align-items: start;
}

.hero-heading {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(28px, 3.5vw, 44px);
  font-weight: 600;
  color: var(--navy);
  margin: 0 0 1rem;
}

.hero-desc {
  font-size: 18px;
  color: var(--charcoal);
  line-height: 1.78;
  max-width: 560px;
  margin-bottom: 1.5rem;
  font-weight: 300;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.tag {
  display: inline-block;
  padding: 4px 12px;
  background: var(--white);
  border: 1px solid var(--border);
  font-size: 12px;
  font-family: 'Crimson Pro', serif;
  letter-spacing: 0.05em;
  color: var(--muted);
}

.hero-issue-card {
  background: var(--navy);
  padding: 2rem;
  color: var(--white);
}

.issue-card-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 0.25rem;
}

.issue-card-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 26px;
  font-weight: 600;
  color: var(--white);
  margin-bottom: 1.25rem;
}

.issue-card-theme {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 1rem;
  margin-bottom: 1rem;
}

.theme-label {
  display: block;
  font-size: 11px;
  color: var(--gold);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 0.3rem;
}

.theme-value {
  font-size: 16px;
  color: rgba(255,255,255,0.85);
  font-style: italic;
  line-height: 1.5;
}

.issue-card-meta {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 1rem;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  font-size: 14px;
  color: rgba(255,255,255,0.55);
  padding: 0.3rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.meta-row span:last-child { color: var(--white); }

/* ARTICLES SECTION */
.section-articles {
  padding: 4rem 0;
  background: var(--white);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 2.5rem;
}

.section-h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 30px;
  font-weight: 600;
  color: var(--navy);
  margin: 0;
}

.all-link {
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--teal);
  text-decoration: none;
  white-space: nowrap;
}
.all-link:hover { color: var(--gold); }

/* FORTHCOMING NOTICE */
.forthcoming-notice {
  border: 1px solid var(--border);
  border-left: 4px solid var(--gold);
  background: var(--cream);
}

.forthcoming-inner {
  display: flex;
  gap: 2rem;
  padding: 2.5rem;
  align-items: flex-start;
}

.forthcoming-icon {
  color: var(--gold);
  font-size: 12px;
  margin-top: 6px;
  flex-shrink: 0;
}

.forthcoming-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--navy);
  margin-bottom: 0.75rem;
}

.forthcoming-text {
  font-size: 17px;
  color: var(--charcoal);
  line-height: 1.75;
  font-weight: 300;
  margin-bottom: 1.5rem;
  max-width: 600px;
}

.forthcoming-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

/* SCOPE */
.section-scope {
  padding: 4rem 0;
  background: var(--cream);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.scope-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
}

.scope-left p {
  font-size: 17px;
  color: var(--charcoal);
  line-height: 1.8;
  font-weight: 300;
  margin-bottom: 1rem;
}

.scope-areas {
  background: var(--white);
  border: 1px solid var(--border);
  padding: 2rem;
}

.scope-area-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.25rem;
}

.scope-item {
  display: flex;
  gap: 0.75rem;
  align-items: baseline;
  padding: 0.45rem 0;
  border-bottom: 1px solid var(--border);
  font-size: 15px;
  color: var(--charcoal);
  line-height: 1.55;
}
.scope-item:last-child { border-bottom: none; }

.scope-dot {
  color: var(--gold);
  font-size: 8px;
  flex-shrink: 0;
  position: relative;
  top: -1px;
}

/* SPECS */
.section-specs {
  padding: 4rem 0;
  background: var(--white);
}

.specs-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  border: 1px solid var(--border);
  margin-top: 1rem;
}

.spec-item {
  padding: 1.25rem 1.5rem;
  border-right: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.spec-item:nth-child(4n) { border-right: none; }
.spec-item:nth-last-child(-n+4) { border-bottom: none; }

.spec-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 0.4rem;
}

.spec-value {
  font-size: 16px;
  color: var(--navy);
  font-weight: 400;
}

/* CFS */
.section-cfs {
  padding: 4.5rem 0;
  background: var(--navy);
  text-align: center;
}

.cfs-heading {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 600;
  color: var(--white);
  margin: 0 0 1.25rem;
}

.cfs-text {
  font-size: 18px;
  color: rgba(255,255,255,0.7);
  line-height: 1.78;
  font-weight: 300;
  margin-bottom: 2rem;
}

.cfs-buttons {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}

.btn-outline-light {
  display: inline-block;
  background: transparent;
  color: rgba(255,255,255,0.8);
  font-family: 'Crimson Pro', serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 10px 22px;
  border: 1.5px solid rgba(255,255,255,0.35);
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
}
.btn-outline-light:hover {
  border-color: var(--white);
  color: var(--white);
}

@media (max-width: 768px) {
  .hero-inner { grid-template-columns: 1fr; }
  .hero-issue-card { display: block; }
  .scope-grid { grid-template-columns: 1fr; gap: 2rem; }
  .specs-grid { grid-template-columns: repeat(2, 1fr); }
  .spec-item:nth-child(2n) { border-right: none; }
  .spec-item:nth-child(4n) { border-right: 1px solid var(--border); }
  .forthcoming-inner { flex-direction: column; gap: 1rem; padding: 1.75rem; }
}
</style>
