---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Guest Editorship" description="Apply to serve as guest editor for a NAHJ Journal special issue.">
  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb"><a href="/">Home</a> / <a href="/review">For Reviewers</a> / Guest Editor</nav>
      <span class="section-label">Guest Editorship</span>
      <div class="gold-rule"></div>
      <h1 class="page-h1">Apply as Guest Editor</h1>
      <p class="page-sub">Guest editors work with our team to commission, review, and shape a special issue or thematic section.</p>
    </div>
  </div>

  <div class="form-body">
    <div class="container">
      <div class="form-layout">
        <div class="form-main">

          <div class="eligibility-box">
            <div class="elig-title">Guest Editor Eligibility</div>
            <div class="elig-list">
              {[
                'Established scholar with relevant disciplinary expertise',
                'Experience commissioning or editing academic work',
                'Ability to recruit contributors and manage timelines',
                'No conflict of interest with prospective contributors',
                'To propose a specific theme, also complete the Special Issue Proposal form',
              ].map(item => (
                <div class="elig-item">
                  <span class="elig-dot">◆</span>
                  <span>{item}</span>
                </div>
              ))}
            </div>
            <div class="info-note" style="margin-top:1rem;padding:0.75rem 1rem;background:rgba(27,94,111,0.08);border-left:3px solid var(--teal);font-size:15px;color:var(--charcoal);">
              To propose a specific theme, also complete the <a href="/review/special-issue">Special Issue Proposal form</a> alongside this application.
            </div>
          </div>

          <form action="https://formspree.io/f/xbdzapeq" method="POST">
            <input type="hidden" name="_subject" value="Guest Editor Application — NAHJ Journal" />
            <div class="form-section">
              <h2 class="form-section-title">Personal Information</h2>
              <div class="form-row-2">
                <div class="form-group">
                  <label for="first_name">First Name *</label>
                  <input type="text" id="first_name" name="first_name" required />
                </div>
                <div class="form-group">
                  <label for="last_name">Last Name *</label>
                  <input type="text" id="last_name" name="last_name" required />
                </div>
              </div>
              <div class="form-row-2">
                <div class="form-group">
                  <label for="email">Email *</label>
                  <input type="email" id="email" name="email" required />
                </div>
                <div class="form-group">
                  <label for="affiliation">Affiliation *</label>
                  <input type="text" id="affiliation" name="affiliation" required />
                </div>
              </div>
            </div>
            <div class="form-section">
              <h2 class="form-section-title">Editorial Experience</h2>
              <div class="form-group">
                <label for="experience">Relevant Editorial or Commissioning Experience *</label>
                <textarea id="experience" name="experience" required rows="5" placeholder="Describe any experience editing collections, special issues, or commissioning academic work"></textarea>
              </div>
              <div class="form-group">
                <label for="theme">Proposed Theme or Area (if applicable)</label>
                <textarea id="theme" name="theme" rows="4" placeholder="If you have a specific theme in mind, describe it here. Also complete the Special Issue Proposal form."></textarea>
              </div>
              <div class="form-group">
                <label for="motivation">Why do you want to guest edit for NAHJ Journal? *</label>
                <textarea id="motivation" name="motivation" required rows="4"></textarea>
              </div>
            </div>
            <div class="form-submit-row">
              <button type="submit" class="btn-primary">Submit Application</button>
            </div>
          </form>
        </div>
        <div class="form-sidebar">
          <div class="sidebar-box">
            <div class="sidebar-box-title">Guest Editor Role</div>
            {[
              'Work with editors to define theme and scope',
              'Commission contributions from scholars',
              'Conduct initial quality assessment',
              'Coordinate with reviewers',
              'Write editorial introduction',
              'Manage contributor communications',
            ].map(item => (
              <div class="check-item">
                <span class="check-icon">◆</span>
                <span>{item}</span>
              </div>
            ))}
          </div>
          <div class="sidebar-box">
            <div class="sidebar-box-title">Related</div>
            <a href="/review/special-issue" class="sidebar-link">Special Issue Proposal →</a>
            <a href="/review/board" class="sidebar-link">Editorial Board →</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
