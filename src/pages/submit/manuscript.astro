---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Submit Manuscript" description="Submit your manuscript to NAHJ Journal.">

  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb"><a href="/">Home</a> / <a href="/submit">Submit</a> / Manuscript</nav>
      <span class="section-label">Submission Form</span>
      <div class="gold-rule"></div>
      <h1 class="page-h1">Submit a Manuscript</h1>
      <p class="page-sub">Complete all required fields. Ensure your manuscript is fully anonymised before uploading.</p>
    </div>
  </div>

  <div class="form-body">
    <div class="container">
      <div class="form-layout">

        <div class="form-main">
          <form action="https://formspree.io/f/mzdjakqe" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="_subject" value="Manuscript Submission — NAHJ Journal" />

            <div class="form-section">
              <h2 class="form-section-title">Author Information</h2>
              <div class="form-row-2">
                <div class="form-group">
                  <label for="first_name">First Name *</label>
                  <input type="text" id="first_name" name="first_name" required placeholder="Your first name" />
                </div>
                <div class="form-group">
                  <label for="last_name">Last Name *</label>
                  <input type="text" id="last_name" name="last_name" required placeholder="Your last name" />
                </div>
              </div>
              <div class="form-row-2">
                <div class="form-group">
                  <label for="email">Email Address *</label>
                  <input type="email" id="email" name="email" required placeholder="your@email.com" />
                </div>
                <div class="form-group">
                  <label for="affiliation">Institutional Affiliation</label>
                  <input type="text" id="affiliation" name="affiliation" placeholder="University or independent" />
                </div>
              </div>
              <div class="form-group">
                <label for="orcid">ORCID iD</label>
                <input type="text" id="orcid" name="orcid" placeholder="0000-0000-0000-0000" />
              </div>
            </div>

            <div class="form-section">
              <h2 class="form-section-title">Manuscript Details</h2>
              <div class="form-group">
                <label for="title">Manuscript Title *</label>
                <input type="text" id="title" name="title" required placeholder="Full title of your manuscript" />
              </div>
              <div class="form-row-2">
                <div class="form-group">
                  <label for="type">Article Type *</label>
                  <select id="type" name="type" required>
                    <option value="">Select article type</option>
                    <option>Research Article</option>
                    <option>Review Essay</option>
                    <option>Research Note</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="wordcount">Word Count *</label>
                  <input type="number" id="wordcount" name="wordcount" required placeholder="Excluding references" />
                </div>
              </div>
              <div class="form-group">
                <label for="focus">Primary Focus Area *</label>
                <select id="focus" name="focus" required>
                  <option value="">Select focus area</option>
                  <option>Cultural and Historical Studies</option>
                  <option>Intellectual History</option>
                  <option>Neuro-Humanities and Cognitive Theory</option>
                  <option>Philosophy of Mind</option>
                  <option>Critical Modernity and Social Dynamics</option>
                  <option>Political Philosophy and Theory</option>
                  <option>Ethics and Moral Philosophy</option>
                  <option>Postcolonial and Decolonial Studies</option>
                  <option>Philosophy of Religion</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="form-group">
                <label for="abstract">Abstract *</label>
                <textarea id="abstract" name="abstract" required rows="6" placeholder="150–250 words summarising your argument and contribution"></textarea>
              </div>
              <div class="form-group">
                <label for="keywords">Keywords *</label>
                <input type="text" id="keywords" name="keywords" required placeholder="4–6 keywords, comma separated" />
              </div>
            </div>

            <div class="form-section">
              <h2 class="form-section-title">Cover Letter</h2>
              <div class="form-group">
                <label for="cover">Cover Letter *</label>
                <textarea id="cover" name="cover" required rows="5" placeholder="Briefly explain the significance and originality of your work. Confirm it has not been published or submitted elsewhere."></textarea>
              </div>
            </div>

            <div class="form-section">
              <h2 class="form-section-title">Declarations</h2>
              <div class="form-check">
                <input type="checkbox" id="original" name="original" required />
                <label for="original" class="check-label">This manuscript is original work and has not been published or submitted elsewhere *</label>
              </div>
              <div class="form-check">
                <input type="checkbox" id="anonymous" name="anonymous" required />
                <label for="anonymous" class="check-label">The manuscript is fully anonymised with all identifying information removed *</label>
              </div>
              <div class="form-check">
                <input type="checkbox" id="guidelines" name="guidelines" required />
                <label for="guidelines" class="check-label">I have read and followed the <a href="/submit">author guidelines</a> *</label>
              </div>
            </div>

            <div class="form-submit-row">
              <button type="submit" class="btn-primary">Submit Manuscript</button>
              <p class="form-note">Your information is used solely to process your submission and is not shared with third parties.</p>
            </div>

          </form>
        </div>

        <div class="form-sidebar">
          <div class="sidebar-box">
            <div class="sidebar-box-title">Before Submitting</div>
            {[
              'Remove all author names and affiliations from the manuscript',
              'Remove acknowledgements and self-citations that identify you',
              'Confirm the manuscript is not under review elsewhere',
              'Check word count is within limits',
              'Apply IJMES transliteration throughout',
              'Format references in Chicago style',
            ].map(item => (
              <div class="check-item">
                <span class="check-icon">✓</span>
                <span>{item}</span>
              </div>
            ))}
          </div>

          <div class="sidebar-box">
            <div class="sidebar-box-title">Word Limits</div>
            <div class="sidebar-dates">
              <div class="date-item">
                <div class="date-label">Research Article</div>
                <div class="date-value">6,000–10,000</div>
              </div>
              <div class="date-item">
                <div class="date-label">Review Essay</div>
                <div class="date-value">3,000–6,000</div>
              </div>
              <div class="date-item">
                <div class="date-label">Research Note</div>
                <div class="date-value">1,500–3,000</div>
              </div>
            </div>
          </div>

          <div class="sidebar-box">
            <div class="sidebar-box-title">Questions</div>
            <p style="font-size:15px;color:var(--muted);font-weight:300;margin-bottom:0.5rem;">Contact the editorial office with any submission queries.</p>
            <a href="mailto:submissions@nahjinstitute.com" style="font-size:13px;color:var(--teal);word-break:break-all;">submissions@nahjinstitute.com</a>
          </div>
        </div>

      </div>
    </div>
  </div>

</BaseLayout>

<style is:global>
.form-body { padding: 3.5rem 0 5rem; background: var(--white); }

.form-layout {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 3.5rem;
  align-items: start;
}

.form-section {
  margin-bottom: 2.5rem;
  padding-bottom: 2.5rem;
  border-bottom: 1px solid var(--border);
}
.form-section:last-of-type { border-bottom: none; }

.form-section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--navy);
  margin: 0 0 1.5rem;
  padding-bottom: 0.75rem;
  border-bottom: 2px solid var(--cream-dark);
}

.form-row-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}

.form-group { margin-bottom: 1.25rem; }

.form-check {
  display: flex;
  gap: 0.75rem;
  align-items: flex-start;
  margin-bottom: 0.75rem;
}

.form-check input[type="checkbox"] {
  width: auto;
  margin-top: 3px;
  flex-shrink: 0;
}

.check-label {
  font-size: 15px;
  font-weight: 400;
  letter-spacing: 0;
  text-transform: none;
  color: var(--charcoal);
  cursor: pointer;
}

.check-label a { color: var(--teal); }

.form-submit-row {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
  padding-top: 1rem;
}

.form-note {
  font-size: 14px;
  color: var(--muted);
  font-weight: 300;
  margin: 0;
}

.check-item {
  display: flex;
  gap: 0.75rem;
  align-items: baseline;
  padding: 0.4rem 0;
  font-size: 14px;
  color: var(--charcoal);
  border-bottom: 1px solid var(--border);
}
.check-item:last-child { border-bottom: none; }

.check-icon {
  color: var(--teal);
  font-weight: 700;
  flex-shrink: 0;
}

@media (max-width: 768px) {
  .form-layout { grid-template-columns: 1fr; }
  .form-row-2 { grid-template-columns: 1fr; }
}
</style>
