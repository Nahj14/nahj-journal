---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');
---

<header class="journal-header">
  <div class="header-identity">
    <div class="identity-inner">
      <a href="/" class="journal-brand">
        <div class="brand-main">
          <span class="brand-nahj">NAHJ</span>
          <span class="brand-journal">JOURNAL</span>
        </div>
        <div class="brand-subtitle">Cultural &amp; Historical Studies · Neuro-Humanities · Critical Modernity · Open Access</div>
      </a>
      <div class="header-meta">
        <span class="issn-label">ISSN (Online) Pending</span>
        <span class="divider">|</span>
        <span class="volume-label">Vol. 1 · Spring 2026</span>
      </div>
    </div>
  </div>

  <nav class="journal-nav" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>Home</a>
      <a href="/archive" class:list={['nav-link', { active: isActive('/archive') }]}>Archive</a>
      <a href="/team" class:list={['nav-link', { active: isActive('/team') }]}>Editorial Team</a>
      <a href="/submit" class:list={['nav-link', { active: isActive('/submit') }]}>Submit</a>
      <a href="/review" class:list={['nav-link', { active: isActive('/review') }]}>For Reviewers</a>
    </div>
  </nav>
</header>

<style is:global>
.journal-header {
  background: var(--navy);
  border-bottom: 3px solid var(--gold);
}

.header-identity {
  padding: 1.75rem 0 1.5rem;
}

.identity-inner {
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
}

.journal-brand {
  text-decoration: none;
  display: inline-block;
}

.brand-main {
  display: flex;
  align-items: baseline;
  gap: 0.6rem;
  margin-bottom: 0.3rem;
}

.brand-nahj {
  font-family: 'Cormorant Garamond', serif;
  font-size: 38px;
  font-weight: 600;
  color: var(--white);
  letter-spacing: 0.12em;
  line-height: 1;
}

.brand-journal {
  font-family: 'Crimson Pro', serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 0.28em;
  text-transform: uppercase;
  position: relative;
  top: -2px;
}

.brand-subtitle {
  font-family: 'Crimson Pro', serif;
  font-size: 13px;
  color: rgba(255,255,255,0.45);
  letter-spacing: 0.06em;
  font-style: italic;
}

.header-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
  padding-bottom: 3px;
}

.issn-label, .volume-label {
  font-family: 'Crimson Pro', serif;
  font-size: 11px;
  color: rgba(255,255,255,0.45);
  letter-spacing: 0.08em;
}

.header-meta .divider {
  color: rgba(255,255,255,0.2);
  font-size: 11px;
}

.journal-nav {
  background: rgba(0,0,0,0.2);
  border-top: 1px solid rgba(200,162,82,0.15);
}

.nav-inner {
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  align-items: center;
  gap: 0;
}

.nav-link {
  font-family: 'Crimson Pro', serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65);
  text-decoration: none;
  padding: 12px 18px;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}

.nav-link:hover {
  color: var(--white);
  border-bottom-color: var(--gold);
}

.nav-link.active {
  color: var(--gold);
  border-bottom-color: var(--gold);
}

@media (max-width: 768px) {
  .header-meta { display: none; }
  .identity-inner { display: block; }
  .brand-nahj { font-size: 30px; }
  .brand-subtitle { font-size: 11px; letter-spacing: 0.03em; }
  .nav-inner { overflow-x: auto; gap: 0; white-space: nowrap; -webkit-overflow-scrolling: touch; }
  .nav-link { padding: 10px 12px; font-size: 12px; }
}
</style>
