---
import JournalHeader from '../components/JournalHeader.astro';
import JournalFooter from '../components/JournalFooter.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  articleMeta?: {
    author?: string;
    pubDate?: string;
    category?: string;
    volume?: string;
    issue?: string;
    doi?: string;
  };
}

const {
  title,
  description = 'NAHJ Journal — A peer-reviewed open access journal publishing transdisciplinary research across cultural and historical studies, neuro-humanities, and critical modernity.',
  ogImage,
  ogType = 'website',
  articleMeta,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'NAHJ Journal';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | {siteName}</title>

  <!-- Open Graph -->
  <meta property="og:site_name" content={siteName} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | ${siteName}`} />
  <meta property="og:description" content={description} />
  {ogImage
    ? <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    : <meta property="og:image" content={new URL('/og-default.png', Astro.site)} />
  }
  {ogType === 'article' && articleMeta?.pubDate && (
    <meta property="article:published_time" content={articleMeta.pubDate} />
  )}
  {ogType === 'article' && articleMeta?.author && (
    <meta property="article:author" content={articleMeta.author} />
  )}
  {ogType === 'article' && articleMeta?.category && (
    <meta property="article:section" content={articleMeta.category} />
  )}

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | ${siteName}`} />
  <meta name="twitter:description" content={description} />
  {ogImage
    ? <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    : <meta name="twitter:image" content={new URL('/og-default.png', Astro.site)} />
  }

  <!-- Google Scholar / Highwire Press citation tags (article pages only) -->
  {articleMeta && (
    <>
      <meta name="citation_journal_title" content={siteName} />
      <meta name="citation_publisher" content="Nahj Institute" />
      {articleMeta.author && <meta name="citation_author" content={articleMeta.author} />}
      <meta name="citation_title" content={title} />
      {articleMeta.pubDate && <meta name="citation_publication_date" content={articleMeta.pubDate.split('T')[0]} />}
      {articleMeta.volume && <meta name="citation_volume" content={articleMeta.volume} />}
      {articleMeta.issue && <meta name="citation_issue" content={articleMeta.issue} />}
      <meta name="citation_abstract_html_url" content={String(canonicalURL)} />
      <meta name="citation_fulltext_html_url" content={String(canonicalURL)} />
      <meta name="citation_language" content="en" />
      {articleMeta.doi && <meta name="citation_doi" content={articleMeta.doi} />}
    </>
  )}

  <!-- JSON-LD: Organisation (all pages) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Nahj Institute",
    "url": "https://nahjinstitute.com",
    "sameAs": ["https://journal.nahjinstitute.com"],
    "publishingPrinciples": "https://journal.nahjinstitute.com/submit"
  })} />

  <!-- JSON-LD: ScholarlyArticle (article pages only) -->
  {articleMeta && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ScholarlyArticle",
      "headline": title,
      "description": description,
      "author": {
        "@type": "Person",
        "name": articleMeta.author ?? "NAHJ Journal"
      },
      "datePublished": articleMeta.pubDate?.split('T')[0],
      "publisher": {
        "@type": "Organization",
        "name": "Nahj Institute",
        "url": "https://nahjinstitute.com"
      },
      "isAccessibleForFree": true,
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "url": String(canonicalURL),
      "isPartOf": {
        "@type": "Periodical",
        "name": "NAHJ Journal",
        "issn": []
      }
    })} />
  )}

  <!-- Extra head content (e.g. per-page meta) -->
  <slot name="head" />

  <!-- Fonts — loaded once here; do NOT @import in CSS -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <JournalHeader />
  <main>
    <slot />
  </main>
  <JournalFooter />
</body>
</html>
